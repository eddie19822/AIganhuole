# 账号登录 API 根地址（默认 https://aiganhuole.com；仅 host，不含路径）
# AUTH_API_BASE=https://aiganhuole.com
# 登录页「前往AI干活网注册」打开的完整 https 链接（不设则打开 {AUTH_API_BASE 的 origin}/register）
# AUTH_REGISTER_URL=https://aiganhuole.com/register

# Pexels https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Mixkit 免费素材：无 API，主进程抓取 `/free-stock-video/search/?s=`（关键词）或首页列表；设为 false 可关闭（遵守 mixkit.co/terms）
# MIXKIT_SCRAPE_ENABLED=false

# 阿里云 DashScope（OpenAI 兼容）：英文画面检索词、口播分段、素材二次排序；即梦生成前可精炼文生视频提示（与口播/镜头更一致）
# https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=
# 已配置 DASHSCOPE 时默认会精炼即梦提示；写 false 可关闭（仍用结构化 must/avoid/检索词拼 prompt）
# JIMENG_PROMPT_REFINE=false
DASHSCOPE_MODEL=qwen-turbo
# Chat Completions 模型降级链（逗号分隔，从左到右优先尝试；左侧建议填更强模型）。某一模型额度用尽 / 无权访问 / 限流等时会自动换下一个。
# 未配置时仅使用 DASHSCOPE_MODEL。参考错误码：https://help.aliyun.com/zh/model-studio/developer-reference/status-codes
# DASHSCOPE_MODEL_CHAIN=qwen-plus,qwen-turbo,qwen-flash
# 设为 false 可关闭「对口播句重排素材」（仍保留多路检索合并）
# DASHSCOPE_RERANK_ENABLED=false
# 低成本提升相关性：参与二次排序的候选条数上限（默认 28，范围约 12～40）
# DASHSCOPE_RERANK_POOL=32

# 每个素材源单次检索拉取条数（默认 8，范围 3～12；Pexels / Pixabay / Mixkit 各取前 N 条再交错合并）
# STOCK_PER_QUERY_PER_SOURCE=8
# Pexels：默认按「约 1080p」选 video_files（长边≤该像素，默认 1920）；调高更接近 4K、下载更慢
# STOCK_PEXELS_MAX_LONG_EDGE=1920
# 渲染层与上行一致时可同步（一般仅用主进程检索可不写）
# VITE_STOCK_PEXELS_MAX_LONG_EDGE=1920

# 前端 Vite：分段后自动搜素材 / 「重新搜索全部素材」时的并发段数（默认 6，范围 1～32；过大可能触发接口限流）
# VITE_STOCK_SEARCH_CONCURRENCY=6
# 候选成片后台下载到本机缓存目录（与导出同一 https 源）的并发数（默认 8，范围 1～32；略增可更快填满缓存，占带宽更多）
# VITE_STOCK_CACHE_CONCURRENCY=8
# Electron 主进程：实际上限（默认 16，范围 1～32；小于前端请求值时以本值为准）
# STOCK_CACHE_MAX_CONCURRENCY=16
# 非选中候选成片仅缓存文件前缀字节数（HTTP Range；默认 2500000≈2.5MB，便于前几秒预览）
# STOCK_PREVIEW_CACHE_BYTES=2500000
# 素材成片下载：设为 1 时优先用 Node fetch（部分网络下可规避 Chromium net::ERR_HTTP2_PROTOCOL_ERROR）；默认走 mainFetch 并在读 body 失败时自动回退 Node
# STOCK_MATERIAL_FETCH_NODE_FIRST=0

# 英文检索词与素材标签的关键词重合预排序（默认开；设为 false 可关闭）
# STOCK_ENGLISH_KEYWORD_BOOST_ENABLED=true

# 文本向量与口播/镜头句对齐（DashScope text-embedding，默认开；与关键词按 STOCK_EMBED_KEYWORD_BLEND 融合预排后再大模型重排）
# DASHSCOPE_EMBEDDING_ENABLED=true
# DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
# 自定义向量接口 URL（国际地域密钥）：参考阿里云 Embedding 文档
# DASHSCOPE_EMBEDDING_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
# 向量得分与关键词重合得分的融合权重（默认 0.68；向量权重越高越依赖语义）
# STOCK_EMBED_KEYWORD_BLEND=0.68

# 本地规则分段：单段最大字数（默认 42，范围 24～120；与云端短段策略大致对齐）
# VITE_MAX_CHARS_PER_SEGMENT=42
# 本地规则分段：少于该字数的段会并入邻段（默认 18，与桌面端 Vite 一致可写进前端 .env）
# VITE_MIN_SEGMENT_CHARS=18
# 口播分段：输出 max_tokens 下限提示（程序会按正文长度加大，但兼容接口通常不得超过 16384）
# DASHSCOPE_SEGMENT_MAX_TOKENS=8192
# 口播分段：单批最大字符数，超过则按句号/逗号等切分后多次调用再合并（默认 3200，范围 1500～6000）
# DASHSCOPE_SEGMENT_CHUNK_CHARS=3200
# 阿里云分段：少于该字数的段会并入邻段（默认 18，范围约 8～48）
# DASHSCOPE_MIN_SEGMENT_CHARS=18
# 阿里云分段：若一段不以句号/问号等收尾（可能被模型从逗号处误切开），与下一段总长≤该值则合并（默认 72，范围约 56～140）
# DASHSCOPE_MERGE_INCOMPLETE_MAX_CHARS=72
# 模型偶发超长段时，按标点硬切的上限（默认 38，范围约 26～56）
# DASHSCOPE_HARD_CAP_SEGMENT_CHARS=38

# ---------- 即梦 AI 视频（推荐：官方视觉智能 OpenAPI，与文档一致）----------
# 文档：即梦 AI-视频生成 3.0 Pro（文生视频）https://www.volcengine.com/docs/85621/1777001
# 提交 CVSync2AsyncSubmitTask / 查询 CVSync2AsyncGetResult
# 视觉接口 req_key 链 JIMENG_VISUAL_REQ_KEY_CHAIN（逗号分隔，额度耗尽或未开通该能力时换下一档）。
# 内置默认三档为即梦 3.0 文生视频（720P→1080P→Pro）；Seedance/其它能力须在火山控制台核对 req_key 后再写到本变量首位（勿使用臆造字符串，否则会报 50200 req_key not supported）。
# JIMENG_VISUAL_REQ_KEY_CHAIN=jimeng_t2v_v30,jimeng_t2v_v30_1080p,jimeng_ti2v_v30_pro
# 仅指定单个视觉 req_key（不配 CHAIN 时）：JIMENG_VISUAL_REQ_KEY=jimeng_ti2v_v30_pro
# 鉴权：火山引擎「访问密钥」IAM
VOLC_ACCESS_KEY_ID=
VOLC_SECRET_ACCESS_KEY=
# 兼容旧变量名（任选其一组）
# VOLC_ACCESSKEY=
# VOLC_SECRETKEY=
# JIMENG_VISUAL_HOST=https://visual.volcengineapi.com
# JIMENG_VISUAL_REGION=cn-north-1
# JIMENG_VISUAL_REQ_KEY=jimeng_ti2v_v30_pro
# JIMENG_VISUAL_ASPECT_RATIO=16:9
# JIMENG_VISUAL_FPS=24
# 与口播时长对齐的档位（秒，逗号分隔；默认 4,5,6,8,10）
# JIMENG_VISUAL_DURATION_TIERS=4,5,6,8,10
# JIMENG_VISUAL_POLL_MAX=120
# JIMENG_VISUAL_POLL_INTERVAL_MS=4000
# JIMENG_VISUAL_SEED=-1
# 关闭「下载到本机再预览」（仅用远程 URL，黑屏时可关掉对照）
# JIMENG_SKIP_LOCAL_PREVIEW=1
# 预览使用 file:// 而非 jimeng-local（一般不推荐）
# JIMENG_PREVIEW_USE_FILE_URL=1

# 火山引擎豆包语音 — 语音合成大模型 V3（SSE），新版控制台仅需 API Key
# 文档：https://www.volcengine.com/docs/6561/1598757
# API Key：https://www.volcengine.com/docs/6561/2119699
VOLC_TTS_API_KEY=
# 若你仍在使用旧变量名，也可只填 VOLC_TTS_ACCESS_TOKEN（与 API Key 相同）
# VOLC_TTS_ACCESS_TOKEN=

# ---------- 成片导出（ffmpeg）----------
# 同时进行「成片 MP4」HTTPS 下载的上限（默认 3，范围 1～16；与 EXPORT_SEGMENT_CONCURRENCY 独立，减轻多路抢带宽/CDN 限速）
# EXPORT_MATERIAL_DOWNLOAD_CONCURRENCY=3
# 单次素材 HTTPS 下载超时（毫秒，默认 900000=15 分钟；CDN 极慢时可增大）
# EXPORT_MATERIALIZE_TIMEOUT_MS=1200000
# 单段豆包 TTS 请求超时（毫秒，默认 180000；接口卡住时可适当增大）
# EXPORT_TTS_TIMEOUT_MS=240000
# 单段 ffmpeg 编码超时（毫秒；不设或 0 表示不限；仅在疑似编码卡死时启用，例如 600000）
# EXPORT_FFMPEG_SEGMENT_TIMEOUT_MS=0
# 同时处理的段数（默认 8，范围 1～16；过大可能占满带宽、CPU 或触发豆包 TTS 限流）
# EXPORT_SEGMENT_CONCURRENCY=8
# 每段内「下载画面 + 豆包配音」已并行；提高本值主要加快「多段之间」重叠度。
# macOS 默认用 VideoToolbox 硬件编码；强制软编 libx264：
# EXPORT_FFMPEG_SOFTWARE=1
# 软编时的 preset / crf（默认 veryfast / 24；更小 crf 画质更好但更慢；preset 可试 superfast）
# EXPORT_FFMPEG_PRESET=veryfast
# EXPORT_FFMPEG_CRF=24
# VideoToolbox 平均码率（默认 10M）
# EXPORT_VTB_BITRATE=10M
# 分段成片帧率（默认 24；原为 30，略降可减轻编码负担）
# EXPORT_SEGMENT_FPS=24
# 导出画布（默认 1280×720）；改为 960×540 等可明显加快编码
# EXPORT_SEGMENT_OUT_W=960
# EXPORT_SEGMENT_OUT_H=540
# 设为 0 跳过字幕烧录（成片无内嵌字幕，速度通常快很多；剪映工程包仍带 SRT）
# EXPORT_BURN_SUBTITLES=0
# 成片导出完成后会在同目录写入「片名.export-timing.json」：每段含 videoKey / videoSource / pageUrl / downloadUrl 与各环节耗时，便于对照慢段素材
# 字幕：未配置时按 EXPORT_SEGMENT_OUT_W 与下边距自动推算折行「半角宽度」（约对齐屏内宽度，减少过早换行）
# 若要手写固定值（16～120）：略增大则更宽、每行更多字
# STORY_STOCK_SUBTITLE_LINE_MAX_WIDTH=52
# 左右安全边距（像素，默认 36；愈小字幕条愈贴近屏幕两侧）
# STORY_STOCK_SUBTITLE_MARGIN_LR=36

# 以下为默认合成参数；桌面端可在「故事全文」面板里自选模型与音色（会覆盖此处用于播放）
# 资源版本（须与音色一致）：seed-tts-1.0 / seed-tts-2.0 等
VOLC_TTS_RESOURCE_ID=seed-tts-1.0

# 音色 speaker，须与 VOLC_TTS_RESOURCE_ID 对应版本的音色列表一致
VOLC_TTS_SPEAKER=zh_female_shuangkuaisisi_moon_bigtts

# 阿里云（可选）若 Key 为新加坡等国际地域，请改为对应完整 URL：
# DASHSCOPE_CHAT_COMPLETIONS_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
